# Firebase / platform service config
google-services.json
GoogleService-Info.plist

# Metro
.metro-health-check*

# local env files
.env
.env.*
!.env.example
!.env.*.example

# test and coverage output
coverage/
.nyc_output/

# TypeScript
*.tsbuildinfo

# editor and OS files
.DS_Store
Thumbs.db
.vscode/
.idea/

